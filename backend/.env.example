# Django secret key for session/CSRF signing
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth Web client (Authorization code flow — client secret stays server-side)
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# Must match an Authorized redirect URI on the OAuth client.
# Local: go through the Vite proxy so the session cookie is set on :5173
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Spreadsheet ID from the sheet URL (/d/<SHEET_ID>/edit)
SHEET_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Local Postgres (docker compose service `db`)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance

# Named Sheets Tables (Insert > Table)
TRANSACTIONS_TABLE=Transactions
COMPUTED_TRANSACTIONS_TABLE=Computed_Transactions
INCOME_EXPENSE_TABLE=Income vs Expense by Month
CATEGORY_TABLE=Category
SOURCES_TABLE=Sources
RECEIPT_TABLE=Receipt
RECEIPT_ITEMS_TABLE=Receipt_Items

# Groq (server-side only)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
